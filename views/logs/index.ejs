<%- include('../components/header', { pageTitle }) %>
<%- include('../components/navbar') %>

<section class="page-hero">
  <div>
    <p class="eyebrow">Daily Log Registry</p>
    <h1 class="page-title">Log history</h1>
    <p class="page-subtitle">Review submitted daily logs and their current approval status.</p>
  </div>

  <% if (currentUser && (currentUser.role === 'intern' || currentUser.role === 'admin')) { %>
    <div class="button-row">
      <a class="button button-primary" href="/logs/new">Add Daily Log</a>
    </div>
  <% } %>
</section>

<section class="table-panel">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Intern</th>
          <th>Time Range</th>
          <th>Hours</th>
          <th>Status</th>
          <th>Task</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach((log) => { %>
          <tr>
            <td data-label="Date"><a href="/logs/<%= log.id %>"><%= formatDate(log.date) %></a></td>
            <td data-label="Intern"><%= log.intern_name %></td>
            <td data-label="Time Range"><%= formatTime(log.time_in) %> - <%= formatTime(log.time_out) %></td>
            <td data-label="Hours"><%= Number(log.hours_worked).toFixed(2) %></td>
            <td data-label="Status"><span class="badge badge-<%= log.status %>"><%= log.status %></span></td>
            <td data-label="Task"><%= log.task_description %></td>
            <td data-label="Actions" class="action-cell">
              <a class="button button-ghost" href="/logs/<%= log.id %>">View</a>
              <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'intern')) { %>
                <a class="button button-secondary" href="/logs/<%= log.id %>/edit">Edit</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../components/app-footer') %>
