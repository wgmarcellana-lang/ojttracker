<%- include('../components/header', { pageTitle }) %>
<%- include('../components/navbar') %>

<section class="page-hero">
  <div>
    <p class="eyebrow"><%= showForm ? 'Admin Form' : 'Admin Records' %></p>
    <h1 class="page-title"><%= showForm ? (mode === 'edit' ? 'Edit supervisor' : 'Add supervisor') : 'Manage supervisors' %></h1>
    <p class="page-subtitle"><%= showForm ? 'Use the fields below to maintain supervisor records, department assignments, and login credentials.' : '' %></p>
  </div>

  <% if (!showForm) { %>
    <div class="button-row">
      <a class="button button-primary" href="/admin/supervisors/new">Add supervisor</a>
      <a class="button button-ghost" href="/admin/dashboard">Admin home</a>
    </div>
  <% } %>
</section>

<% if (showForm) { %>
  <section class="panel form-card">
    <ul class="error-list" data-form-errors <%= errors && errors.length ? '' : 'hidden' %>>
      <% if (errors && errors.length) { %>
        <% errors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      <% } %>
    </ul>

    <form
      data-api-form
      data-api-action="<%= mode === 'edit' ? '/admin/supervisors/' + supervisor.id + '/update' : '/admin/supervisors' %>"
      class="form-grid">
      <div class="field">
        <label for="name">Supervisor name</label>
        <input class="input" id="name" name="name" type="text" value="<%= formData.name %>">
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input class="input" id="email" name="email" type="email" value="<%= formData.email %>">
      </div>

      <div class="field field-full">
        <label for="department">Department</label>
        <input class="input" id="department" name="department" type="text" value="<%= formData.department %>">
      </div>

      <div class="field">
        <label for="username">Username</label>
        <input class="input" id="username" name="username" type="text" value="<%= formData.username %>">
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input class="input" id="password" name="password" type="text" value="<%= formData.password %>">
      </div>

      <div class="field field-full">
        <div class="button-row">
          <button class="button button-primary" type="submit"><%= mode === 'edit' ? 'Save changes' : 'Create supervisor' %></button>
          <a class="button button-ghost" href="/admin/supervisors">Back to supervisors</a>
        </div>
      </div>
    </form>

    <% if (mode === 'edit') { %>
      <form data-api-form data-api-action="/admin/supervisors/<%= supervisor.id %>/delete" data-success-redirect="/admin/supervisors" style="margin-top: 16px;">
        <button class="button button-danger" type="submit">Delete supervisor</button>
      </form>
    <% } %>
  </section>
<% } %>

<section class="table-panel" style="margin-top: <%= showForm ? '22px' : '0' %>;">
  <div class="table-header">
    <div>
      <h2>Supervisor list</h2>
      <p class="muted">Intern counts update automatically from current assignments.</p>
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Username</th>
          <th>Email</th>
          <th>Department</th>
          <th>Interns</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
      <% supervisors.forEach((item) => { %>
        <tr>
          <td data-label="Name"><strong><%= item.name %></strong></td>
          <td data-label="Username"><%= item.username || 'No account' %></td>
          <td data-label="Email"><%= item.email %></td>
          <td data-label="Department"><%= item.department %></td>
          <td data-label="Interns"><%= item.intern_count %></td>
          <td data-label="Actions" class="action-cell">
            <a class="button button-secondary" href="/admin/supervisors/<%= item.id %>/edit">Edit</a>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../components/app-footer') %>
