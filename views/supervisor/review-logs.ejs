<%- include('../components/header', { pageTitle }) %>
<%- include('../components/navbar') %>

<section class="page-hero">
  <div>
    <p class="eyebrow">Supervisor Queue</p>
    <h1 class="page-title">Review submitted logs</h1>
    <p class="page-subtitle">Approve only the entries that should count toward required internship hours.</p>
  </div>
</section>

<section class="table-panel">
  <% if (!logs.length) { %>
    <div class="empty-state">No logs available for review.</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Intern</th>
            <th>Hours</th>
            <th>Status</th>
            <th>Task</th>
            <th>Review</th>
          </tr>
        </thead>
        <tbody>
        <% logs.forEach((log) => { %>
          <tr>
            <td data-label="Date"><a href="/logs/<%= log.id %>"><%= formatDate(log.date) %></a></td>
            <td data-label="Intern"><%= log.intern_name %></td>
            <td data-label="Hours"><%= Number(log.hours_worked).toFixed(2) %></td>
            <td data-label="Status"><span class="badge badge-<%= log.status %>"><%= log.status %></span></td>
            <td data-label="Task"><%= log.task_description %></td>
            <td data-label="Review" class="review-cell">
              <div class="review-actions">
                <form data-api-form data-api-action="/supervisors/logs/<%= log.id %>/approve" data-success-redirect="/supervisors/review-logs" class="review-action-form">
                  <ul class="error-list" data-form-errors hidden></ul>
                    <div class="review-inline-group">
                      <input class="input review-note-input" name="supervisor_comment" placeholder="Optional note">
                      <button class="button button-primary" type="submit">Approve</button>
                    </div>
                  </form>
                  <form data-api-form data-api-action="/supervisors/logs/<%= log.id %>/reject" data-success-redirect="/supervisors/review-logs" class="review-action-form">
                    <ul class="error-list" data-form-errors hidden></ul>
                    <div class="review-inline-group">
                      <input class="input review-note-input" name="supervisor_comment" placeholder="Reason for rejection">
                      <button class="button button-danger" type="submit">Reject</button>
                    </div>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../components/app-footer') %>
